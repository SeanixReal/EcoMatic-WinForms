# Eco-Matic WinForms DB configuration
# Use either ECOMATIC_DB_CONNECTION_STRING or the individual variables below.

# ECOMATIC_DB_CONNECTION_STRING=Server=127.0.0.1;Port=3306;Database=ecomatic_winforms_db;User ID=root;Password=your_password;SslMode=None;

ECOMATIC_DB_HOST=127.0.0.1
ECOMATIC_DB_PORT=3306
ECOMATIC_DB_NAME=ecomatic_winforms_db
ECOMATIC_DB_USER=root
ECOMATIC_DB_PASSWORD=your_password
